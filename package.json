{
  "name": "orb-modpack-exporter",
  "productName": "ORB Modpack Exporter",
  "version": "2.0.7",
  "description": "Collaborate via GitHub, export .mrpack files, and track changes",
  "main": ".vite/build/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/OR-Beyond/modpack-exporter.git"
  },
  "homepage": "https://github.com/OR-Beyond/modpack-exporter#readme",
  "bugs": {
    "url": "https://github.com/OR-Beyond/modpack-exporter/issues"
  },
  "desktopName": "orb-modpack-exporter",
  "scripts": {
    "start": "npm run build && electron .",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "lint": "tsc --noEmit",
    "test": "npm run lint",
    "package": "npm run build && electron-builder --config electron-builder.config.cjs --dir",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "release": "npm run build && electron-builder --config electron-builder.config.cjs --publish always"
  },
  "author": "ORB Team",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.4.5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.18",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "isomorphic-git": "^1.38.6",
    "js-yaml": "^4.3.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0"
  }
}
