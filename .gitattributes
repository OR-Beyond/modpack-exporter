# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Shell scripts — must stay LF
*.sh text eol=lf

# Windows-specific — keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries — never touch
*.png binary
*.ico binary
*.icns binary
*.jar binary
*.zip binary
